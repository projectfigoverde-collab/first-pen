---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const schema = [
  {
    "@type": "WebPage",
    "@id": "https://firstsecurity.com.br/segmentos/#webpage",
    "url": "https://firstsecurity.com.br/segmentos",
    "name": "Pentest por Segmento: Fintechs, Bancos, SaaS, E-commerce e Governo | First Security",
    "description": "Pentest especializado por segmento de mercado: fintechs, instituições financeiras, SaaS B2B, e-commerce e órgãos governamentais.",
    "isPartOf": { "@id": "https://firstsecurity.com.br/#website" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://firstsecurity.com.br" },
        { "@type": "ListItem", "position": 2, "name": "Segmentos", "item": "https://firstsecurity.com.br/segmentos" }
      ]
    }
  }
];

const segmentos = [
  {
    sigla: 'Fintech',
    nome: 'Fintechs e Pagamentos',
    href: '/segmentos/pentest-fintech',
    desc: 'Segurança para startups financeiras: APIs de pagamento, Open Finance, carteiras digitais e conformidade com BACEN e PCI DSS.'
  },
  {
    sigla: 'Banco',
    nome: 'Bancos e Instituições Financeiras',
    href: '/segmentos/pentest-bancos',
    desc: 'Pentest para bancos tradicionais e digitais: internet banking, mobile banking, core bancário e obrigações regulatórias.'
  },
  {
    sigla: 'SaaS',
    nome: 'SaaS e Empresas de Tecnologia',
    href: '/segmentos/pentest-saas',
    desc: 'Segurança para produtos SaaS B2B: multi-tenancy, isolamento de dados de clientes, APIs e conformidade com SOC 2.'
  },
  {
    sigla: 'E-com',
    nome: 'E-commerce e Varejo Digital',
    href: '/segmentos/pentest-e-commerce',
    desc: 'Proteção para lojas virtuais: checkout, dados de cartão, contas de clientes, fraude e conformidade com PCI DSS.'
  },
  {
    sigla: 'Gov',
    nome: 'Governo e Setor Público',
    href: '/segmentos/pentest-governo',
    desc: 'Pentest para órgãos públicos e sistemas governamentais: portais cidadão, sistemas legados, dados sensíveis e LGPD.'
  },
];
---

<BaseLayout
  title="Pentest por Segmento: Fintechs, Bancos, SaaS, E-commerce | First Security"
  description="Pentest especializado por segmento de mercado. A First Security conhece as ameaças e regulamentações específicas de cada setor."
  canonical="/segmentos"
  schema={schema}
>
  <Breadcrumbs items={[{ label: 'Segmentos' }]} />

  <section style="padding:var(--space-16) 0 var(--space-12);background:linear-gradient(135deg,rgba(10,31,61,0.03) 0%,rgba(0,180,255,0.05) 100%);" aria-labelledby="segmentosH1">
    <div class="container" style="max-width:900px">
      <span class="badge badge-cyan" style="margin-bottom:16px;">Por setor de atuação</span>
      <h1 id="segmentosH1" class="t-display-lg" style="color:var(--color-navy);margin-bottom:20px;">Pentest especializado por segmento</h1>
      <p class="t-body-lg" style="color:var(--color-slate);max-width:700px;margin-bottom:32px;">
        Cada setor enfrenta ameaças específicas e está sujeito a regulamentações diferentes. A First Security adapta metodologia, escopo e relatório às particularidades do seu segmento.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="segmentosListTitle">
    <div class="container">
      <div class="section-header">
        <div class="section-eyebrow">Setores atendidos</div>
        <h2 id="segmentosListTitle" class="section-title">Escolha seu segmento</h2>
      </div>
      <div class="grid-3">
        {segmentos.map((s) => (
          <a href={s.href} class="card" style="text-decoration:none;display:block;">
            <div style="display:inline-block;background:var(--color-navy);color:white;font-family:var(--font-mono);font-size:11.5px;font-weight:700;padding:3px 10px;border-radius:var(--radius-sm);margin-bottom:12px;">{s.sigla}</div>
            <h3 class="t-heading-md" style="color:var(--color-navy);margin-bottom:8px;">{s.nome}</h3>
            <p style="font-size:13.5px;color:var(--color-slate);line-height:1.6;">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-off-white);" aria-labelledby="porqueSegTitle">
    <div class="container" style="max-width:860px">
      <div class="section-header">
        <div class="section-eyebrow">Por que especialização importa</div>
        <h2 id="porqueSegTitle" class="section-title">Pentest genérico versus especializado por setor</h2>
      </div>
      <div class="prose">
        <p>Um pentest de e-commerce precisa testar fluxos de checkout, cupons de desconto, gestão de estoque e contas de clientes de formas que não se aplicam a um SaaS B2B. Um pentest em fintech precisa avaliar transações PIX, limites por usuário e APIs do Open Finance com conhecimento regulatório que não está em um checklist genérico.</p>
        <p>A First Security desenvolve casos de teste customizados para cada setor, combinando a metodologia técnica (OWASP, PTES, NIST) com o conhecimento de negócio específico do segmento. O resultado é uma cobertura mais completa e achados mais relevantes para o seu contexto.</p>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="ctaSegmentos">
    <div class="container text-center">
      <h2 id="ctaSegmentos" class="section-title" style="color:white;">Pentest adaptado ao seu segmento</h2>
      <p class="section-subtitle" style="color:rgba(255,255,255,0.65);margin:0 auto var(--space-8);">
        Metodologia, escopo e relatório ajustados às ameaças e regulamentações específicas do seu setor.
      </p>
      <a href="/orcamento" class="btn btn-cyan btn-lg">Solicitar orçamento</a>
    </div>
  </section>
</BaseLayout>
