---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const schema = [
  {
    "@type": "WebPage",
    "@id": "https://firstsecurity.com.br/compliance/#webpage",
    "url": "https://firstsecurity.com.br/compliance",
    "name": "Pentest para Compliance: LGPD, PCI DSS, ISO 27001, BACEN e SOC 2 | First Security",
    "description": "Hub de compliance da First Security: como o pentest atende requisitos de LGPD, PCI DSS 4.0, ISO 27001, BACEN 4.893 e SOC 2 Type II.",
    "isPartOf": { "@id": "https://firstsecurity.com.br/#website" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://firstsecurity.com.br" },
        { "@type": "ListItem", "position": 2, "name": "Compliance", "item": "https://firstsecurity.com.br/compliance" }
      ]
    }
  }
];

const frameworks = [
  { sigla: 'LGPD', nome: 'Lei Geral de Proteção de Dados', href: '/compliance/pentest-lgpd', desc: 'Como o pentest apoia a conformidade com a Lei 13.709/2018 e demonstra medidas técnicas de segurança à ANPD.' },
  { sigla: 'PCI DSS', nome: 'Payment Card Industry Data Security Standard', href: '/compliance/pentest-pci-dss', desc: 'Requisitos 11.3 e 11.4 do PCI DSS 4.0 que exigem testes de penetração internos e externos anuais.' },
  { sigla: 'ISO 27001', nome: 'Information Security Management', href: '/compliance/pentest-iso-27001', desc: 'Controle A.12.6 da ISO 27001:2022 e como o pentest contribui para o SGSI e auditorias de certificação.' },
  { sigla: 'BACEN', nome: 'Banco Central do Brasil', href: '/compliance/pentest-bacen', desc: 'Resolução 4.893/2021 e Circular 3.909: obrigações de teste de segurança para instituições financeiras.' },
  { sigla: 'SOC 2', nome: 'System and Organization Controls 2', href: '/compliance/pentest-soc-2', desc: 'Como o pentest suporta os critérios de disponibilidade, confidencialidade e segurança do SOC 2 Type II.' },
  { sigla: 'NIST CSF', nome: 'NIST Cybersecurity Framework', href: '/compliance/pentest-nist-csf', desc: 'Alinhamento com as funções Govern, Identify, Protect, Detect, Respond e Recover do NIST CSF 2.0 via metodologia NIST SP 800-115.' },
];
---

<BaseLayout
  title="Pentest para Compliance: LGPD, PCI DSS, ISO 27001, BACEN e SOC 2 | First Security"
  description="Hub de compliance da First Security: como o pentest atende requisitos de LGPD, PCI DSS 4.0, ISO 27001, BACEN 4.893 e SOC 2. Relatórios para auditoria incluídos."
  canonical="/compliance"
  schema={schema}
>
  <Breadcrumbs items={[{ label: 'Compliance' }]} />

  <section style="padding:var(--space-16) 0 var(--space-12);background:linear-gradient(135deg,rgba(10,31,61,0.03) 0%,rgba(0,180,255,0.05) 100%);" aria-labelledby="complianceH1">
    <div class="container" style="max-width:900px">
      <span class="badge badge-cyan" style="margin-bottom:16px;">Segurança e regulamentação</span>
      <h1 id="complianceH1" class="t-display-lg" style="color:var(--color-navy);margin-bottom:20px;">Pentest para compliance</h1>
      <p class="t-body-lg" style="color:var(--color-slate);max-width:700px;margin-bottom:32px;">
        Regulamentações como PCI DSS, LGPD, ISO 27001 e BACEN exigem ou recomendam explicitamente testes de penetração periódicos. A First Security entrega relatórios formatados para auditores, com rastreabilidade dos requisitos atendidos por cada achado do pentest.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="frameworksTitle">
    <div class="container">
      <div class="section-header">
        <div class="section-eyebrow">Frameworks e regulamentações</div>
        <h2 id="frameworksTitle" class="section-title">Compliance coberto</h2>
      </div>
      <div class="grid-3">
        {frameworks.map((f) => (
          <a href={f.href} class="card" style="text-decoration:none;display:block;">
            <div style="display:inline-block;background:var(--color-navy);color:white;font-family:var(--font-mono);font-size:11.5px;font-weight:700;padding:3px 10px;border-radius:var(--radius-sm);margin-bottom:12px;">{f.sigla}</div>
            <h3 class="t-heading-md" style="color:var(--color-navy);margin-bottom:8px;">{f.nome}</h3>
            <p style="font-size:13.5px;color:var(--color-slate);line-height:1.6;">{f.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-off-white);" aria-labelledby="relatorioComplianceTitle">
    <div class="container" style="max-width:860px">
      <div class="section-header">
        <div class="section-eyebrow">Entregável</div>
        <h2 id="relatorioComplianceTitle" class="section-title">Relatório mapeado para auditores</h2>
      </div>
      <div class="prose">
        <p>Cada vulnerabilidade no relatório da First Security é mapeada para os controles e requisitos dos frameworks aplicáveis ao seu ambiente. Isso facilita a apresentação para auditores externos e reduz o tempo de resposta a questionamentos de compliance.</p>
        <p>O relatório inclui: evidências reproduzíveis com screenshots, CVSS calculado por especialista, impacto em linguagem de negócio, rastreabilidade para requisitos específicos (ex: PCI DSS 11.3.1, ISO A.12.6.1) e plano de remediação priorizado por criticidade.</p>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="ctaCompliance">
    <div class="container text-center">
      <h2 id="ctaCompliance" class="section-title" style="color:white;">Pentest com relatório para auditoria</h2>
      <p class="section-subtitle" style="color:rgba(255,255,255,0.65);margin:0 auto var(--space-8);">
        Atenda seus requisitos de compliance com evidências concretas e relatório formatado para auditores.
      </p>
      <a href="/orcamento" class="btn btn-cyan btn-lg">Solicitar orçamento</a>
    </div>
  </section>
</BaseLayout>
