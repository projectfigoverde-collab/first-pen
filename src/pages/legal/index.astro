---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const schema = [
  {
    "@type": "WebPage",
    "@id": "https://firstsecurity.com.br/legal/#webpage",
    "url": "https://firstsecurity.com.br/legal",
    "name": "Documentos Legais | First Security",
    "description": "Documentos legais da First Security: termos de uso, política de privacidade, política de cookies e política de divulgação responsável.",
    "isPartOf": { "@id": "https://firstsecurity.com.br/#website" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://firstsecurity.com.br" },
        { "@type": "ListItem", "position": 2, "name": "Legal", "item": "https://firstsecurity.com.br/legal" }
      ]
    }
  }
];

const docs = [
  { titulo: 'Termos de Uso', href: '/legal/termos-de-uso', desc: 'Condições de uso do site, propriedade intelectual e limitações de responsabilidade.' },
  { titulo: 'Política de Privacidade', href: '/legal/politica-de-privacidade', desc: 'Como tratamos dados pessoais conforme a LGPD (Lei 13.709/2018): bases legais, finalidades e seus direitos.' },
  { titulo: 'Política LGPD Simplificada', href: '/legal/politica-lgpd', desc: 'Versão resumida do tratamento de dados pessoais com foco nos direitos dos titulares.' },
  { titulo: 'Política de Cookies', href: '/legal/politica-de-cookies', desc: 'Quais cookies usamos, para que servem e como gerenciar suas preferências.' },
  { titulo: 'Divulgação Responsável', href: '/legal/politica-de-divulgacao-responsavel', desc: 'Como reportar vulnerabilidades identificadas em nossos sistemas de forma coordenada.' },
];
---

<BaseLayout
  title="Documentos Legais | First Security"
  description="Documentos legais da First Security: termos de uso, política de privacidade, política de cookies e política de divulgação responsável de vulnerabilidades."
  canonical="/legal"
  schema={schema}
>
  <Breadcrumbs items={[{ label: 'Legal' }]} />

  <section style="padding:var(--space-16) 0 var(--space-12);" aria-labelledby="legalH1">
    <div class="container" style="max-width:760px">
      <span class="badge badge-navy" style="margin-bottom:16px;">Transparência e conformidade</span>
      <h1 id="legalH1" class="t-display-lg" style="color:var(--color-navy);margin-bottom:20px;">Documentos legais</h1>
      <p class="t-body-lg" style="color:var(--color-slate);max-width:600px;">
        Documentos que regem o uso do site firstsecurity.com.br e o tratamento de dados pessoais conforme a LGPD.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;" aria-labelledby="docsLegaisTitle">
    <div class="container" style="max-width:760px">
      <div style="display:flex;flex-direction:column;gap:0;border:1px solid var(--color-slate-200);border-radius:var(--radius-lg);overflow:hidden;">
        {docs.map((doc, i) => (
          <a href={doc.href} style={`display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 24px;text-decoration:none;${i > 0 ? 'border-top:1px solid var(--color-slate-200);' : ''}`}>
            <div>
              <div style="font-size:15px;font-weight:600;color:var(--color-navy);margin-bottom:4px;">{doc.titulo}</div>
              <div style="font-size:13px;color:var(--color-slate);line-height:1.5;">{doc.desc}</div>
            </div>
            <span style="color:var(--color-cyan-600);font-size:18px;flex-shrink:0;">&#8594;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
