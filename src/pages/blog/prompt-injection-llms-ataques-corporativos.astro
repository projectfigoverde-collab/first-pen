    "headline": "Prompt Injection em LLMs: os ataques que estão chegando nas aplicações corporativas",
    "description": "Como funcionam os ataques de prompt injection em sistemas baseados em Large Language Models, vetores de exploração e como proteger aplicações que integram IA.",
    "datePublished": "2025-03-08",
    "dateModified": "2025-03-08",
    "author": { "@id": "https://firstsecurity.com.br/#organization" },
    "publisher": { "@id": "https://firstsecurity.com.br/#organization" },
    "inLanguage": "pt-BR",
    "url": "https://firstsecurity.com.br/blog/prompt-injection-llms-ataques-corporativos",
    "keywords": ["prompt injection", "LLM security", "AI security", "segurança IA", "OWASP LLM Top 10"],
    "articleSection": "Vulnerabilidades",
    "isPartOf": { "@id": "https://firstsecurity.com.br/blog/#blog" }
  },
  {
    "@type": "WebPage",
    "@id": "https://firstsecurity.com.br/blog/prompt-injection-llms-ataques-corporativos/#webpage",
    "url": "https://firstsecurity.com.br/blog/prompt-injection-llms-ataques-corporativos",
    "name": "Prompt Injection em LLMs: ataques em aplicações corporativas | First Security",
    "description": "Como funcionam os ataques de prompt injection em sistemas baseados em Large Language Models, vetores de exploração e como proteger aplicações que integram IA.",
    "isPartOf": { "@id": "https://firstsecurity.com.br/#website" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://firstsecurity.com.br" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://firstsecurity.com.br/blog" },
        { "@type": "ListItem", "position": 3, "name": "Prompt Injection em LLMs", "item": "https://firstsecurity.com.br/blog/prompt-injection-llms-ataques-corporativos" }
      ]
    }
  }
