---
const year = new Date().getFullYear();
---

<style>
.footer {
  background: var(--color-navy);
  color: rgba(255,255,255,0.75);
}

.footer-main {
  padding: var(--space-16) 0 var(--space-12);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr;
  gap: var(--space-8);
}

@media (max-width: 1024px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr 1fr;
  }
}

@media (max-width: 640px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
  }
  .footer-brand { grid-column: 1 / -1; }
}

.footer-brand-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: var(--space-4);
  text-decoration: none;
}

.footer-brand-name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 17px;
  letter-spacing: -0.025em;
}

.footer-brand-name .first { color: white; }
.footer-brand-name .security { color: var(--color-cyan); }

.footer-tagline {
  font-size: 13.5px;
  line-height: 1.6;
  color: rgba(255,255,255,0.55);
  margin-bottom: var(--space-5);
  max-width: 260px;
}

.social-links {
  display: flex;
  gap: var(--space-3);
}

.social-link {
  width: 34px;
  height: 34px;
  border-radius: var(--radius-md);
  background: rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.6);
  transition: all 0.15s;
  text-decoration: none;
}

.social-link:hover {
  background: rgba(0,180,255,0.2);
  color: var(--color-cyan);
}

.footer-col-title {
  font-size: 11px;
  font-weight: 700;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: var(--space-4);
}

.footer-link {
  display: block;
  font-size: 13.5px;
  color: rgba(255,255,255,0.6);
  padding: 4px 0;
  transition: color 0.1s;
  text-decoration: none;
}

.footer-link:hover {
  color: var(--color-cyan-400);
}

/* Newsletter */
.footer-newsletter {
  background: rgba(255,255,255,0.04);
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  padding: var(--space-10) 0;
}

.newsletter-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}

@media (max-width: 768px) {
  .newsletter-inner { flex-direction: column; align-items: flex-start; }
}

.newsletter-text h3 {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: white;
  margin-bottom: var(--space-2);
}

.newsletter-text p {
  font-size: 13.5px;
  color: rgba(255,255,255,0.55);
  max-width: 400px;
  line-height: 1.5;
}

.newsletter-form {
  display: flex;
  gap: var(--space-2);
  flex-shrink: 0;
}

.newsletter-input {
  padding: 10px 14px;
  border-radius: var(--radius-md);
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.06);
  color: white;
  font-size: 14px;
  font-family: var(--font-body);
  width: 260px;
  transition: border-color 0.15s;
}

.newsletter-input::placeholder { color: rgba(255,255,255,0.35); }
.newsletter-input:focus {
  outline: none;
  border-color: var(--color-cyan);
  background: rgba(255,255,255,0.08);
}

/* Barra legal */
.footer-legal {
  padding: var(--space-5) 0;
}

.legal-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
}

.legal-copy {
  font-size: 12px;
  color: rgba(255,255,255,0.35);
}

.legal-links {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.legal-link {
  font-size: 12px;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  transition: color 0.1s;
}

.legal-link:hover { color: rgba(255,255,255,0.65); }
</style>

<footer class="footer">

  <!-- Colunas principais -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">

        <!-- Marca -->
        <div class="footer-brand">
          <a href="/" class="footer-brand-logo" aria-label="First Security, página inicial">
            <svg width="28" height="28" viewBox="0 0 100 100" aria-hidden="true">
              <defs>
                <linearGradient id="ftGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#FFFFFF"/>
                  <stop offset="100%" stop-color="#CCEEFF"/>
                </linearGradient>
              </defs>
              <path d="M50 8 L86 28 L86 72 L50 92 L14 72 L14 28 Z" fill="none" stroke="url(#ftGrad)" stroke-width="6" stroke-linejoin="round"/>
              <path d="M40 30 L40 70 L46 70 L46 38 L36 38" fill="none" stroke="url(#ftGrad)" stroke-width="6" stroke-linejoin="round" stroke-linecap="round"/>
            </svg>
            <span class="footer-brand-name">
              <span class="first">First</span><span class="security">Security</span>
            </span>
          </a>
          <p class="footer-tagline">
            Empresa especializada em pentest, Red Team e Purple Team para empresas no Brasil.
          </p>
          <div class="social-links">
            <a href="https://www.linkedin.com/company/firstsecurity" class="social-link" aria-label="LinkedIn First Security" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://github.com/firstsecurity" class="social-link" aria-label="GitHub First Security" rel="noopener noreferrer" target="_blank">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
            </a>
          </div>
        </div>

        <!-- Servicos -->
        <div>
          <div class="footer-col-title">Serviços</div>
          <a href="/servicos/pentest-web" class="footer-link">Pentest Web</a>
          <a href="/servicos/pentest-mobile" class="footer-link">Pentest Mobile</a>
          <a href="/servicos/pentest-api" class="footer-link">Pentest API</a>
          <a href="/servicos/pentest-cloud" class="footer-link">Pentest Cloud</a>
          <a href="/servicos/pentest-as-a-service" class="footer-link">PTaaS</a>
          <a href="/red-team" class="footer-link">Red Team</a>
          <a href="/servicos/purple-team" class="footer-link">Purple Team</a>
          <a href="/servicos" class="footer-link" style="color:var(--color-cyan-400);margin-top:4px;">Ver todos</a>
        </div>

        <!-- Setores -->
        <div>
          <div class="footer-col-title">Setores</div>
          <a href="/segmentos/pentest-fintech" class="footer-link">Fintechs</a>
          <a href="/segmentos/pentest-bancos" class="footer-link">Bancos</a>
          <a href="/segmentos/pentest-saas" class="footer-link">SaaS B2B</a>
          <a href="/segmentos/pentest-e-commerce" class="footer-link">E-commerce</a>
          <a href="/segmentos/pentest-governo" class="footer-link">Governo</a>
          <a href="/segmentos" class="footer-link" style="color:var(--color-cyan-400);margin-top:4px;">Ver todos</a>
        </div>

        <!-- Conhecimento -->
        <div>
          <div class="footer-col-title">Conhecimento</div>
          <a href="/pentest/o-que-e" class="footer-link">O que é pentest</a>
          <a href="/pentest/tipos" class="footer-link">Tipos de pentest</a>
          <a href="/pentest/quanto-custa" class="footer-link">Quanto custa</a>
          <a href="/blog" class="footer-link">Blog</a>
          <a href="/glossario" class="footer-link">Glossário</a>
          <a href="/comparativos" class="footer-link">Comparativos</a>
        </div>

        <!-- Compliance -->
        <div>
          <div class="footer-col-title">Compliance</div>
          <a href="/compliance/pentest-lgpd" class="footer-link">LGPD</a>
          <a href="/compliance/pentest-pci-dss" class="footer-link">PCI DSS</a>
          <a href="/compliance/pentest-iso-27001" class="footer-link">ISO 27001</a>
          <a href="/compliance/pentest-bacen" class="footer-link">BACEN</a>
          <a href="/compliance/pentest-soc-2" class="footer-link">SOC 2</a>
          <a href="/compliance" class="footer-link" style="color:var(--color-cyan-400);margin-top:4px;">Ver tudo</a>
        </div>

        <!-- Empresa -->
        <div>
          <div class="footer-col-title">Empresa</div>
          <a href="/quem-somos" class="footer-link">Quem somos</a>
          <a href="/quem-somos/metodologia" class="footer-link">Metodologia</a>
          <a href="/quem-somos/equipe" class="footer-link">Equipe</a>
          <a href="/casos-de-uso" class="footer-link">Casos de uso</a>
          <a href="/contato" class="footer-link">Contato</a>
          <a href="/onde-atendemos" class="footer-link">Onde atendemos</a>
        </div>

      </div>
    </div>
  </div>

  <!-- Newsletter -->
  <div class="footer-newsletter">
    <div class="container">
      <div class="newsletter-inner">
        <div class="newsletter-text">
          <h3>Conteúdo técnico mensal</h3>
          <p>Pentest, Red Team e tendências de cibersegurança ofensiva no Brasil. Sem spam, apenas o que é relevante.</p>
        </div>
        <form class="newsletter-form" action="#" method="post" aria-label="Formulario de newsletter">
          <label class="sr-only" for="footerEmail">Seu email</label>
          <input
            type="email"
            id="footerEmail"
            name="email"
            class="newsletter-input"
            placeholder="seu@email.com.br"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn btn-cyan btn-sm">Assinar</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Barra legal -->
  <div class="footer-legal">
    <div class="container">
      <div class="legal-inner">
        <p class="legal-copy">
          &copy; {year} First Security. Todos os direitos reservados.
        </p>
        <div class="legal-links">
          <a href="/legal/politica-de-privacidade" class="legal-link">Privacidade</a>
          <a href="/legal/termos-de-uso" class="legal-link">Termos de uso</a>
          <a href="/legal/politica-lgpd" class="legal-link">Política LGPD</a>
          <a href="/legal/politica-de-cookies" class="legal-link">Cookies</a>
          <a href="/legal/politica-de-divulgacao-responsavel" class="legal-link">Divulgação responsável</a>
        </div>
      </div>
    </div>
  </div>

</footer>
